  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "puppeteer": "^24.43.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
